@model PAS.Web.ViewModels.PaginatedStudentProposalPageViewModel

@{
    ViewData["Title"] = "My Proposals";
}

<div class="student-dash-hero">
    <div>
        <h2>My Proposals</h2>
        <p>Track your proposal status, supervisor visibility, and uploaded files.</p>
    </div>

    <div class="student-dash-hero-actions">
        <a asp-controller="Proposal" asp-action="Create" class="btn btn-light">Submit New Proposal</a>
        <a asp-controller="Proposal" asp-action="Dashboard" class="btn btn-outline-light">Dashboard</a>
    </div>
</div>

<div class="student-stats-grid">
    <div class="student-stat-card">
        <span>Total</span>
        <h3>@Model.Summary.TotalProposals</h3>
    </div>
    <div class="student-stat-card">
        <span>Pending</span>
        <h3>@Model.Summary.PendingCount</h3>
    </div>
    <div class="student-stat-card">
        <span>Under Review</span>
        <h3>@Model.Summary.UnderReviewCount</h3>
    </div>
    <div class="student-stat-card">
        <span>Matched</span>
        <h3>@Model.Summary.MatchedCount</h3>
    </div>
    <div class="student-stat-card">
        <span>Rejected</span>
        <h3>@Model.Summary.RejectedCount</h3>
    </div>
    <div class="student-stat-card">
        <span>Withdrawn</span>
        <h3>@Model.Summary.WithdrawnCount</h3>
    </div>
</div>

<div class="student-panel">
    <div class="student-panel-title">Proposal List</div>

    @if (!Model.Proposals.Any())
    {
            <div class="alert alert-info mb-0">No proposals found.</div>
    }
    else
    {
            <table class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Research Area</th>
                        <th>Status</th>
                        <th>Supervisor</th>
                        <th>File</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Proposals)
                {
                            <tr>
                                <td>@item.Title</td>
                                <td>@item.ResearchArea</td>
                                <td>@item.Status</td>
                                <td>@item.SupervisorEmail</td>
                                <td>
                            @if (item.HasUploadedFile)
                            {
                                            <div>@item.FileName</div>
                                            <a asp-controller="Proposal" asp-action="DownloadProposalFile" asp-route-id="@item.Id" class="btn btn-sm btn-secondary mt-2">
                                                Download
                                            </a>
                            }
                            else
                            {
                                            <span>No file</span>
                            }
                                </td>
                                <td>
                            @if (item.Status != "Matched")
                            {
                                            <a asp-controller="Proposal" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary mb-2">
                                                Edit
                                            </a>

                                            <form asp-controller="Proposal" asp-action="Withdraw" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="btn btn-sm btn-danger">Withdraw</button>
                                            </form>
                            }
                            else
                            {
                                            <span class="text-muted">Locked</span>
                            }
                                </td>
                            </tr>
                }
                </tbody>
            </table>

        @if (Model.TotalPages > 1)
        {
                    <nav class="mt-3">
                        <ul class="pagination">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                        <a class="page-link" asp-action="MyProposals" asp-route-page="@i">@i</a>
                                    </li>
                    }
                        </ul>
                    </nav>
        }
    }
</div>