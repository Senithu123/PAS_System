@model PAS.Web.ViewModels.ProposalDetailsViewModel

@{
    ViewData["Title"] = "Proposal Details";
}

<h2 class="mb-4">Proposal Details</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <h4 class="card-title">@Model.Title</h4>
        <hr />

        <p><strong>Proposal ID:</strong> @Model.Id</p>
        <p><strong>Research Area:</strong> @Model.ResearchArea</p>
        <p><strong>Status:</strong> @Model.Status</p>
        <p>
            <strong>Identity Reveal:</strong>
            @if (Model.IsIdentityRevealed)
            {
                    <span class="text-success fw-bold">Revealed</span>
            }
            else
            {
                    <span class="text-danger">Hidden</span>
            }
        </p>

        <p><strong>Abstract:</strong></p>
        <div class="border rounded p-3 mb-3 bg-light">
            @Model.Abstract
        </div>

        <p><strong>Technical Stack:</strong></p>
        <div class="border rounded p-3 mb-3 bg-light">
            @Model.TechnicalStack
        </div>

        <p><strong>Student Email:</strong> @Model.StudentEmail</p>
        <p><strong>Supervisor Email:</strong> @Model.SupervisorEmail</p>

        <a asp-action="Proposals" class="btn btn-secondary">Back to Proposals</a>
    </div>
</div>