@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using PAS.Core.Entities
@using PAS.Infrastructure.Data
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject ApplicationDbContext DbContext

@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();

    var isLandingPage = controller == "Home" && action == "Index";
    var isAuthPage = controller == "Account";

    var unreadNotificationCount = 0;

    if (SignInManager.IsSignedIn(User))
    {
        var currentUserId = UserManager.GetUserId(User);
        if (!string.IsNullOrEmpty(currentUserId))
        {
            unreadNotificationCount = await DbContext.Notifications
                .CountAsync(n => n.UserId == currentUserId && !n.IsRead);
        }
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PAS</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PAS.Web.styles.css" asp-append-version="true" />

    <style>
        html, body {
            height: 100%;
            margin: 0 !important;
        }

        body {
            min-height: 100vh !important;
        }

        .app-shell {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .page-content {
            flex: 1 0 auto;
            width: 100%;
        }

        .footer {
            position: static !important;
            bottom: auto !important;
            left: auto !important;
            right: auto !important;
            width: 100% !important;
            margin-top: 24px !important;
            padding: 18px 0 !important;
            background: #fff !important;
            border-top: 1px solid #E5E7EB !important;
            flex-shrink: 0;
            z-index: auto !important;
        }
    </style>
</head>
<body>
    <div class="app-shell">
        @if (!isLandingPage && !isAuthPage)
        {
            <header>
                <nav class="navbar navbar-expand-lg navbar-dark">
                    <div class="container-fluid">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            if (User.IsInRole("Admin") || User.IsInRole("SystemAdmin"))
                            {
                                <a class="navbar-brand fw-bold" asp-controller="Admin" asp-action="Dashboard">PAS</a>
                            }
                            else if (User.IsInRole("Supervisor"))
                            {
                                <a class="navbar-brand fw-bold" asp-controller="Supervisor" asp-action="Dashboard">PAS</a>
                            }
                            else if (User.IsInRole("PendingSupervisor"))
                            {
                                <a class="navbar-brand fw-bold" asp-controller="Account" asp-action="PendingApproval">PAS</a>
                            }
                            else
                            {
                                <a class="navbar-brand fw-bold" asp-controller="Proposal" asp-action="Dashboard">PAS</a>
                            }
                        }
                        else
                        {
                            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">PAS</a>
                        }

                        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                            <span class="navbar-toggler-icon"></span>
                        </button>

                        <div class="collapse navbar-collapse" id="mainNavbar">
                            <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-lg-1">
                                @if (SignInManager.IsSignedIn(User))
                                {
                                    @if (User.IsInRole("Admin") || User.IsInRole("SystemAdmin"))
                                    {
                                        <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Dashboard">Dashboard</a></li>
                                        <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="ManageStudents">Manage Students</a></li>
                                        <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="ManageSupervisors">Manage Supervisors</a></li>
                                        <li class="nav-item"><a class="nav-link" asp-controller="SupervisorRequests" asp-action="Index">Supervisor Requests</a></li>
                                        <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="ResearchAreas">Research Areas</a></li>
                                        <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Users">All Users</a></li>
                                        <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Proposals">Proposals</a></li>
                                        <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Results">Results</a></li>
                                        <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Report">Reports</a></li>
                                        <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Settings">Settings</a></li>
                                        <li class="nav-item">
                                            <a class="nav-link notification-nav-link" asp-controller="Notification" asp-action="Index">
                                                Notifications
                                                @if (unreadNotificationCount > 0)
                                                {
                                                    <span class="notification-badge">@unreadNotificationCount</span>
                                                }
                                            </a>
                                        </li>
                                    }
                                    else if (User.IsInRole("Supervisor"))
                                    {
                                        <li class="nav-item"><a class="nav-link" asp-controller="Supervisor" asp-action="Dashboard">Dashboard</a></li>
                                        <li class="nav-item"><a class="nav-link" asp-controller="Supervisor" asp-action="SubmitTopic">Submit Topics</a></li>
                                        <li class="nav-item"><a class="nav-link" asp-controller="Supervisor" asp-action="MyTopics">My Topics</a></li>
                                        <li class="nav-item"><a class="nav-link" asp-controller="Supervisor" asp-action="SetExpertise">Set Expertise</a></li>
                                        <li class="nav-item"><a class="nav-link" asp-controller="Supervisor" asp-action="Browse">Browse Proposals</a></li>
                                        <li class="nav-item"><a class="nav-link" asp-controller="Supervisor" asp-action="AssignedStudents">Assigned Students</a></li>
                                        <li class="nav-item"><a class="nav-link" asp-controller="Supervisor" asp-action="Profile">Profile</a></li>
                                        <li class="nav-item">
                                            <a class="nav-link notification-nav-link" asp-controller="Notification" asp-action="Index">
                                                Notifications
                                                @if (unreadNotificationCount > 0)
                                                {
                                                    <span class="notification-badge">@unreadNotificationCount</span>
                                                }
                                            </a>
                                        </li>
                                    }
                                    else if (User.IsInRole("PendingSupervisor"))
                                    {
                                        <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="PendingApproval">Pending Approval</a></li>
                                    }
                                    else
                                    {
                                        <li class="nav-item"><a class="nav-link" asp-controller="Proposal" asp-action="Dashboard">Dashboard</a></li>
                                        <li class="nav-item"><a class="nav-link" asp-controller="Proposal" asp-action="Create">Submit Proposal</a></li>
                                        <li class="nav-item"><a class="nav-link" asp-controller="Proposal" asp-action="MyProposals">My Proposals</a></li>
                                        <li class="nav-item"><a class="nav-link" asp-controller="Proposal" asp-action="MatchResult">Match Result</a></li>
                                        <li class="nav-item"><a class="nav-link" asp-controller="Proposal" asp-action="AvailableProjects">Available Projects</a></li>
                                        <li class="nav-item"><a class="nav-link" asp-controller="Proposal" asp-action="MyPreferences">My Preferences</a></li>
                                        <li class="nav-item"><a class="nav-link" asp-controller="Proposal" asp-action="Profile">Profile</a></li>
                                        <li class="nav-item">
                                            <a class="nav-link notification-nav-link" asp-controller="Notification" asp-action="Index">
                                                Notifications
                                                @if (unreadNotificationCount > 0)
                                                {
                                                    <span class="notification-badge">@unreadNotificationCount</span>
                                                }
                                            </a>
                                        </li>
                                    }
                                }
                                else
                                {
                                    <li class="nav-item">
                                        <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                                    </li>
                                }
                            </ul>

                            <div class="d-flex align-items-center">
                                <partial name="_LoginPartial" />
                            </div>
                        </div>
                    </div>
                </nav>
            </header>
        }

        <main class="page-content @(isLandingPage || isAuthPage ? "" : "container-fluid py-3")" role="main">
            @RenderBody()
        </main>

        @if (!isLandingPage && !isAuthPage)
        {
            <footer class="footer text-muted">
                <div class="container-fluid">
                    &copy; 2026 - Project Approval System
                </div>
            </footer>
        }
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>