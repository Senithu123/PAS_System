@model PAS.Web.ViewModels.RegisterSupervisorViewModel

@{
    ViewData["Title"] = "Apply as Supervisor";
}

<div class="auth-page-wrap">
    <div class="auth-shell">
        <div class="auth-left-panel">
            <div class="auth-brand">
                <img src="~/images/pas-logo.png" alt="PAS Logo" class="auth-logo" />
                <span>Project Approval System</span>
            </div>

            <div class="auth-left-content">
                <h1>Supervisor Application</h1>
                <p>
                    Submit your supervisor application. Your account will be reviewed and approved by an administrator.
                </p>

                <div class="auth-feature-list">
                    <div class="auth-feature-item">Apply for supervisor access</div>
                    <div class="auth-feature-item">Wait for admin approval</div>
                    <div class="auth-feature-item">Set expertise after approval</div>
                </div>
            </div>
        </div>

        <div class="auth-right-panel">
            <div class="auth-form-card">
                <div class="auth-form-header">
                    <h2>Apply as Supervisor</h2>
                    <p>Fill in your details to submit a supervisor request.</p>
                </div>

                <form asp-action="RegisterSupervisor" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label"></label>
                        <input asp-for="FullName" class="form-control auth-input" placeholder="Enter your full name" />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control auth-input" placeholder="Enter your email" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Department" class="form-label"></label>
                        <input asp-for="Department" class="form-control auth-input" placeholder="Enter your department" />
                        <span asp-validation-for="Department" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="RequestedExpertise" class="form-label"></label>
                        <input asp-for="RequestedExpertise" class="form-control auth-input" placeholder="Enter your expertise area" />
                        <span asp-validation-for="RequestedExpertise" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label"></label>
                        <textarea asp-for="Notes" class="form-control auth-input" placeholder="Optional notes"></textarea>
                        <span asp-validation-for="Notes" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" class="form-control auth-input" placeholder="Create a password" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label"></label>
                        <input asp-for="ConfirmPassword" class="form-control auth-input" placeholder="Confirm your password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn auth-submit-btn">Submit Supervisor Application</button>

                    <div class="auth-bottom-text">
                        Want a normal student account?
                        <a asp-action="RegisterStudent" asp-controller="Account">Register as student</a>
                    </div>

                    <div class="auth-bottom-text mt-2">
                        Already have an account?
                        <a asp-action="Login" asp-controller="Account">Sign in</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}